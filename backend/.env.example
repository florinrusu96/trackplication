# Local dev defaults to zero-setup SQLite — just fill in ANTHROPIC_API_KEY.
# (Leave DATABASE_URL unset to use the SQLite default; override only if you
#  want to point local dev at Postgres.)
# DATABASE_URL=sqlite:///./trackplication.db
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Auth — set a strong random JWT_SECRET (>=32 bytes) in production.
JWT_SECRET=dev-secret-change-me-in-production-only

STATIC_DIR=
LOG_LEVEL=


# Extraction backend: 'anthropic' (Claude API) or 'ollama' (free local model).
# Local dev uses ollama — no API credits needed. Requires: ollama running +
# `ollama pull llama3.2`. Switch to anthropic to test the real Claude path.
EXTRACTION_PROVIDER=ollama
OLLAMA_MODEL=gemma4:e4b
# OLLAMA_BASE_URL=http://localhost:11434
