# Local dev defaults to zero-setup SQLite — just fill in ANTHROPIC_API_KEY.
# (Leave DATABASE_URL unset to use the SQLite default; override only if you
#  want to point local dev at Postgres.)
# DATABASE_URL=sqlite:///./trackplication.db
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Auth — set a strong random JWT_SECRET (>=32 bytes) in production.
JWT_SECRET=dev-secret-change-me-in-production-only

STATIC_DIR=
